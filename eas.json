{
    "cli": {
        "version": ">= 10.0.0",
        "requireCommit": false
    },
    "build": {
        "development": {
            "android": {
                "buildType": "apk",
                "gradleCommand": ":app:assembleDebug"
            },
            "ios": {
                "simulator": true
            },
            "env": {
                "NODE_ENV": "development",
                "EXPO_PUBLIC_API_URL": "https://scrapx-br.vercel.app/api",
                "EXPO_PUBLIC_WS_URL": "https://scrapx-br.vercel.app"
            }
        },
        "preview": {
            "distribution": "internal",
            "android": {
                "buildType": "apk"
            },
            "env": {
                "NODE_ENV": "production",
                "EXPO_PUBLIC_API_URL": "https://scrapx-br.vercel.app/api",
                "EXPO_PUBLIC_WS_URL": "https://scrapx-br.vercel.app"
            }
        },
        "production": {
            "android": {
                "buildType": "apk"
            },
            "env": {
                "NODE_ENV": "production",
                "EXPO_PUBLIC_API_URL": "https://scrapx-br.vercel.app/api",
                "EXPO_PUBLIC_WS_URL": "https://scrapx-br.vercel.app"
            }
        }
    },
    "submit": {
        "production": {}
    }
}