{
  "expo": {
    "name": "ScrapBazaar Customer",
    "slug": "scrapbazaar-customer",
    "version": "1.0.0",
    "sdkVersion": "52.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "backgroundColor": "#f0fdf4"
    },
    "android": {
      "package": "com.scrapbazaar.customer",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.scrapbazaar.customer"
    },
    "plugins": [
      "expo-location",
      "expo-image-picker",
      "expo-notifications"
    ]
  }
}